# Токен Telegram бота (получить у @BotFather)
TG_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Цифровой ID Telegram-канала, обычно начинается с -100
CHANNEL_ID=-1001234567890

# Токен VK API с доступом к чтению стены
VK_TOKEN=vk1a.ABCdef...GHIjkl

# ID сообщества VK — с минусом; ID страницы пользователя — положительный
GROUP_ID=-123456789

# Как часто проверять новые посты (в секундах), 3600 = 1 час, 1800 = 30 минут, 900 = 15 минут
CHECK_INTERVAL=3600

# Таймаут запроса к VK API (в секундах)
REQUEST_TIMEOUT=30

# Пути к файлу состояния и логам
LAST_POST_FILE=last_post.json
LOG_FILE=logs/bot.log

# Уровень и ротация логов: bot.log + 5 архивов по 10 МБ
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Версия Docker-образа: latest или номер релиза, например 1.1.0
BOT_VERSION=latest
